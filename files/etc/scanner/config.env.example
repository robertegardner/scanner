# Scanner configuration — copy to /etc/scanner/config.env and edit.
# Loaded by both scanner-scheduler.service and scanner-ui.service.

# Ports
SCHEDULER_PORT=8082
UI_PORT=8081

# RTL-SDR device
# Run `rtl_test -t` to confirm the Nooelec appears at index 0.
SDR_DEVICE_INDEX=0

# SDRTrunk
# Path to the SDRTrunk launcher script (installed by bootstrap.sh).
SDRTRUNK_BIN=/opt/scanner/sdrtrunk/sdr-trunk-latest
# SDRTrunk home dir — playlist XML and recordings live here.
SDRTRUNK_HOME=/var/lib/scanner/sdrtrunk

# Recording output directories
# EMS_RECORDINGS_DIR must match where SDRTrunk actually saves call audio.
# NOTE: SDRTrunk ignores SDRTRUNK_HOME and uses <scanner-home>/SDRTrunk
# (capital S) = /var/lib/scanner/SDRTrunk/recordings. Point this there.
EMS_RECORDINGS_DIR=/var/lib/scanner/SDRTrunk/recordings
MANUAL_RECORDINGS_DIR=/var/lib/scanner/manual

# Icecast live streaming
# ICECAST_STREAM_URL is served to browsers as the live audio player source.
# Set to the public-facing Icecast URL (or localhost:8000 for LAN-only access).
# Mount /ems.mp3 is added to the SDRTrunk playlist — source password must also
# be set manually in /var/lib/scanner/SDRTrunk/playlist/default.xml.
ICECAST_STREAM_URL=https://icecast.rg2.io/ems.mp3

# Monitor page streaming (rtl_fm → ffmpeg → Icecast)
# MONITOR_ICECAST_URL: ffmpeg source URL including password, used server-side only.
# MONITOR_STREAM_URL: public-facing listener URL served to browsers.
MONITOR_ICECAST_URL=icecast://source:hackme@localhost:8000/monitor.mp3
MONITOR_STREAM_URL=https://icecast.rg2.io/monitor.mp3

# Post-rtl_fm audio filter chains, applied by ffmpeg via -af for the live
# monitor stream. Edit these to taste — they're plain ffmpeg filter graphs.
#
# The {squelch} placeholder is substituted at runtime: when the dashboard
# Squelch toggle is ON, MONITOR_AUDIO_SQUELCH gets inserted; when OFF, it's
# removed. Position {squelch} where you want the gate (typically right after
# the band-limit filters and before any nonlinear processing).
#
# AM chain — tuned for ATC voice on 118-137 MHz:
#   1. de-ring notches: the Nooelec puts a fixed digital birdie + harmonics
#      into the AM audio at 464 / 898 / 1797 / 2695 Hz (898 Hz fundamental ×n,
#      measured 2026-06-02). dynaudnorm pumps it ~15x during dead air, so it
#      "rings" in silence. Narrow equalizer notches (g=-26..-34) kill it ~20-35 dB
#      with negligible voice impact. These sit BEFORE {squelch} so the gate
#      judges clean, post-notch silence — not the birdie.
#   2. compand transfer points: quiet voice (-22 dBFS RMS) gets +4 dB, mid
#      voice (-13) gets +12 dB, then mild compression above. NOTE: lifting the
#      low end harder to chase weak ground stations (e.g. KCGI Tower) was tried
#      twice and SUBJECTIVELY sounds QUIETER — the boosted noise floor makes
#      dynaudnorm/alimiter ride the whole signal down. -22/-18 is the sweet
#      spot; weak-tower loudness is an RF/antenna limit, not a DSP one.
#
# NOTE: dynaudnorm's g (gausssize) default is 31 (~7.5s lookahead) which
# exceeds Icecast's source-timeout and silently kills the stream during
# startup. Keep g <= 15 for anything published to Icecast.
MONITOR_AUDIO_FILTER_AM=highpass=f=200, lowpass=f=3400, equalizer=f=464:width_type=h:width=22:g=-26, equalizer=f=898:width_type=h:width=40:g=-34, equalizer=f=1797:width_type=h:width=70:g=-30, equalizer=f=2695:width_type=h:width=90:g=-22, {squelch}compand=attacks=0.05:decays=0.3:points=-60/-60|-22/-18|-13/-1|-2/-4:soft-knee=4:gain=0, dynaudnorm=p=0.95:m=15:s=10:g=15, alimiter=level_in=1:level_out=0.95:limit=0.95:attack=5:release=50
MONITOR_AUDIO_FILTER_FM=highpass=f=80, lowpass=f=5000, {squelch}dynaudnorm=p=0.85:m=15:s=10:g=11

# Audio gate (squelch) filter — inserted at {squelch} when the dashboard
# toggle is ON. Because the AM chain notches the birdie BEFORE this gate, dead
# air is now genuinely quiet (~-50 dBFS+), so the threshold drops to 0.015
# (~-36 dBFS): high enough to mute clean silence, low enough to pass weak tower
# voice (the old 0.06 ≈ -24 dBFS sat above the birdie AND above quiet tower, so
# squelch-on muted the tower entirely). release=200 ms keeps dead air tight.
MONITOR_AUDIO_SQUELCH=agate=threshold=0.015:ratio=6:attack=15:release=200:detection=rms:link=average

# Default squelch state on scheduler startup (true = on, more pleasant for
# casual listening; false = off if you want to hear the noise floor).
MONITOR_SQUELCH_DEFAULT=true

# MP3 bitrate for monitor stream + on-disk recordings (mono).
MONITOR_AUDIO_BITRATE=64k

# Default duration (seconds) for one-click preset tunes from the dashboard.
# Max enforced by MonitorJob is 28800 (8h). Bump higher if you park on a freq.
MONITOR_DEFAULT_DURATION_S=3600

# Scheduler autopilot — when true, EMS auto-starts. Set to false while you're
# listening manually and don't want the scheduler preempting your tunes. The
# HTTP API stays up either way.
SCHEDULER_AUTOPILOT=true

# EMS-default — when true (and autopilot is false), MOSWIN P25 runs as the
# background default: starts on boot, logs calls, yields to a manual aviation
# tune, and resumes after. Ignored if autopilot=true.
#
# COEXISTENCE NOTE: SDRTrunk (MOSWIN) only uses the Nooelec, but on startup it
# enumerates the radio project's SDRplay and knocks the radio off its dongle.
# bootstrap.sh restricts libsdrplay_api.so to the 'radio' group so SDRTrunk skips
# the RSP and the two run simultaneously. If you enable always-on MOSWIN WITHOUT
# that lib restriction in place, it will take down the radio's FM stream.
SCHEDULER_EMS_DEFAULT=true

# On-disk recordings made by the dashboard Record button. Directory must be
# writable by the scanner user. Files are MP3 captured from the live stream
# (post-filter), so they sound like what the listener heard.
RECORDINGS_DIR=/var/lib/scanner/recordings

# Local Icecast listening URL the recording ffmpeg subscribes to. Should
# resolve from the Pi itself (use localhost). The default matches the mount
# point in MONITOR_ICECAST_URL above.
RECORDING_SOURCE_URL=http://localhost:8000/monitor.mp3

# --- Transcription (optional; scanner-transcribe.service) -------------------
# Live captions + EMS call text via a remote faster-whisper service. The Pi has
# no GPU, so this reuses the radio project's GPU host (same WHISPER_URL/TOKEN as
# /etc/sdr-streams/captions.env). It degrades gracefully when that host is
# offline — captions just stop updating, nothing else is affected.
#
# The orchestrator transcribes whichever source is active: each SDRTrunk EMS
# call MP3 is transcribed whole (sidecar text shown on /calls), and the live
# monitor stream is window-captioned while the monitor job is running. All
# transcripts are appended to TRANSCRIPTS_DIR/YYYY-MM-DD.jsonl for /transcript.
TRANSCRIBE_ENABLED=true
WHISPER_URL=http://gpu-host.example.com:8088
WHISPER_TOKEN=PASTE_WHISPER_TOKEN_FROM_GPU_HOST
TRANSCRIPTS_DIR=/var/lib/scanner/transcripts
# Rolling window (seconds) sent to Whisper for the live monitor stream.
TRANSCRIBE_WINDOW_SEC=8
# When Whisper first reconnects, only transcribe EMS calls newer than this many
# hours (avoids backfilling the whole recordings history into the log). Future
# calls are always transcribed. 0 = no cap (transcribe everything).
TRANSCRIBE_CALL_MAX_AGE_H=6
# Local Icecast mount to caption for the monitor job (defaults to
# RECORDING_SOURCE_URL if unset).
#TRANSCRIBE_MONITOR_URL=http://localhost:8000/monitor.mp3
