# Scanner configuration — copy to /etc/scanner/config.env and edit.
# Loaded by both scanner-scheduler.service and scanner-ui.service.

# Ports
SCHEDULER_PORT=8082
UI_PORT=8081

# RTL-SDR device
# Run `rtl_test -t` to confirm the Nooelec appears at index 0.
SDR_DEVICE_INDEX=0

# SDRTrunk
# Path to the SDRTrunk launcher script (installed by bootstrap.sh).
SDRTRUNK_BIN=/opt/scanner/sdrtrunk/sdr-trunk-latest
# SDRTrunk home dir — playlist XML and recordings live here.
SDRTRUNK_HOME=/var/lib/scanner/sdrtrunk

# Recording output directories
# EMS_RECORDINGS_DIR must match where SDRTrunk saves calls.
# SDRTrunk defaults to <SDRTRUNK_HOME>/recordings/ — keep them aligned.
EMS_RECORDINGS_DIR=/var/lib/scanner/sdrtrunk/recordings
NOAA_DATA_DIR=/var/lib/scanner/noaa
MANUAL_RECORDINGS_DIR=/var/lib/scanner/manual

# Icecast live streaming
# ICECAST_STREAM_URL is served to browsers as the live audio player source.
# Set to the public-facing Icecast URL (or localhost:8000 for LAN-only access).
# Mount /ems.mp3 is added to the SDRTrunk playlist — source password must also
# be set manually in /var/lib/scanner/SDRTrunk/playlist/default.xml.
ICECAST_STREAM_URL=https://icecast.rg2.io/ems.mp3
