<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<!--
  SDRTrunk playlist — Cape Girardeau County MOSWIN (APCO P25 Phase II, 700 MHz).

  RadioReference source: https://www.radioreference.com/db/sid/6847
  System: Missouri Statewide Wireless Interoperable Network (MOSWIN)
  System ID: 1CE  |  WACN: BEE00  |  NAC: 0x1C3 (decimal 451)

  Cape Girardeau sites (all 700 MHz — NOT VHF):
    Site 033 (Cape Girardeau 700)   CC: 769.16875, 769.41875 MHz
    Site 055 (Cape Girardeau City)  CC: 770.28125, 770.58125 MHz
    Site 060 (Trail of Tears 700)   CC: 769.15625, 769.40625 MHz

  Antenna note: 700 MHz requires a wideband antenna (discone rated 25-1300 MHz).
  A VHF dipole tuned for 140 MHz will NOT receive this band.

  This file is installed to:
    /var/lib/scanner/sdrtrunk/playlists/cape-county.xml
  by bootstrap.sh (only if that file does not already exist).
-->
<playlist timestamp="2026-05-23T00:00:00.000Z" version="2">
    <channel enabled="true" autoStart="true" order="0">
        <name>Cape County MOSWIN</name>

        <decodeConfiguration type="P25_PHASE1">
            <!--
              Control channel modulation is C4FM/CQPSK (Phase 1 FSK) even on Phase II
              sites — SDRTrunk auto-detects TDMA voice from the control channel messages.
            -->
            <modulation>CQPSK</modulation>
            <!-- Skip data/PDU bursts (GPS pings, MDT frames) — voice calls only. -->
            <ignoreDataCalls>true</ignoreDataCalls>
            <!--
              NAC filter: only decode traffic matching MOSWIN's NAC 0x1C3 (= 451).
              Prevents latching onto adjacent systems on nearby frequencies.
            -->
            <nac>451</nac>
        </decodeConfiguration>

        <sourceConfiguration type="TUNER">
            <!--
              Site 033 (Cape Girardeau 700) primary control channel.
              769.16875 MHz × 1,000,000 = 769168750 Hz
              Alternate: 769418750 (secondary CC on same site)
            -->
            <frequency>769168750</frequency>
            <!--
              Pin to the Nooelec RTL-SDR by serial number. Prevents SDRTrunk
              from grabbing the RSPdx-R2 (the radio project's dongle) during
              device enumeration at startup.
              Serial confirmed via: rtl_test -t  → SN: 22012952
            -->
            <preferredTunerName>22012952</preferredTunerName>
        </sourceConfiguration>

        <recordConfiguration>
            <!-- MBE_CALL_SEQUENCE records each decoded voice call as an MP3. -->
            <recorder type="MBE_CALL_SEQUENCE"/>
        </recordConfiguration>

    </channel>
</playlist>
