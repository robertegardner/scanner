<!--
  SDRTrunk v4 playlist — Cape Girardeau County MOSWIN (APCO P25 Phase 1, 700 MHz).

  RadioReference source: https://www.radioreference.com/db/sid/6847
  System: Missouri Statewide Wireless Interoperable Network (MOSWIN)
  System ID: 1CE  |  WACN: BEE00  |  NAC: 0x1CC (decimal 460, confirmed on-air 2026-06-01)
  Modulation: C4FM ("Normal") — confirmed on-air. CQPSK/LSM does NOT decode this CC.

  Cape Girardeau sites (all 700 MHz — NOT VHF):
    Site 033 (Cape Girardeau 700)   CC: 769.16875, 769.41875 MHz
    Site 055 (Cape Girardeau City)  CC: 770.28125, 770.58125 MHz
    Site 060 (Trail of Tears 700)   CC: 769.15625, 769.40625 MHz

  Antenna note: 700 MHz requires a wideband antenna (discone rated 25-1300 MHz).
  A VHF dipole tuned for 140 MHz will NOT receive this band.

  Format notes:
  - Must be version="4". SDRTrunk's PlaylistUpdater migrates v2→v4 and destroys
    P25 channel config in the process. Always use v4 directly.
  - NAC is auto-discovered from the control channel; no NAC filter needed in v4.
  - preferred_tuner is not set here; the RSPdxR2 is disabled via
    tuner_configuration.json so SDRTrunk automatically picks the RTL-2832.
  - Replace CHANGE_ME with your Icecast source password before first install.

  Installed to /var/lib/scanner/SDRTrunk/playlist/default.xml by deploy.sh
  (only if that file does not already exist).
-->
<playlist version="4">
<!-- TALKGROUPS:BEGIN (generated from p25/moswin_talkgroups.tsv by gen_aliases.py — edit the TSV, not here) -->
  <alias color="-16711936" group="" name="Cape County All" list="MOSWIN">
    <id type="talkgroupRange" protocol="APCO25" min="0" max="65535"/>
    <id type="broadcastChannel" channel="MOSWIN Live"/>
    <id type="record"/>
  </alias>
  <alias color="-16776961" group="" name="CGPD Events" list="MOSWIN">
    <id type="talkgroup" value="4206" protocol="APCO25"/>
    <id type="broadcastChannel" channel="MOSWIN Live"/>
    <id type="record"/>
  </alias>
  <alias color="-16776961" group="" name="Jackson PD" list="MOSWIN">
    <id type="talkgroup" value="4229" protocol="APCO25"/>
    <id type="broadcastChannel" channel="MOSWIN Live"/>
    <id type="record"/>
  </alias>
  <alias color="-16776961" group="" name="Sheriff / Law Disp" list="MOSWIN">
    <id type="talkgroup" value="4237" protocol="APCO25"/>
    <id type="broadcastChannel" channel="MOSWIN Live"/>
    <id type="record"/>
  </alias>
  <alias color="-65536" group="" name="Fire Paging" list="MOSWIN">
    <id type="talkgroup" value="4242" protocol="APCO25"/>
    <id type="broadcastChannel" channel="MOSWIN Live"/>
    <id type="record"/>
  </alias>
  <alias color="-16776961" group="" name="SEMO Univ Police" list="MOSWIN">
    <id type="talkgroup" value="4244" protocol="APCO25"/>
    <id type="broadcastChannel" channel="MOSWIN Live"/>
    <id type="record"/>
  </alias>
  <alias color="-16711936" group="" name="Region E HSRT" list="MOSWIN">
    <id type="talkgroup" value="4246" protocol="APCO25"/>
    <id type="broadcastChannel" channel="MOSWIN Live"/>
    <id type="record"/>
  </alias>
  <alias color="-65536" group="" name="Fire Dispatch" list="MOSWIN">
    <id type="talkgroup" value="4249" protocol="APCO25"/>
    <id type="broadcastChannel" channel="MOSWIN Live"/>
    <id type="record"/>
  </alias>
  <alias color="-16776961" group="" name="CGPD SWAT" list="MOSWIN">
    <id type="talkgroup" value="4250" protocol="APCO25"/>
    <id type="broadcastChannel" channel="MOSWIN Live"/>
    <id type="record"/>
  </alias>
<!-- TALKGROUPS:END -->
<channel name="Cape County MOSWIN" enabled="true" order="0">
    <alias_list_name>MOSWIN</alias_list_name>
    <event_log_configuration/>
    <source_configuration type="sourceConfigTuner" frequency="769168750" source_type="TUNER"/>
    <aux_decode_configuration/>
    <decode_configuration type="decodeConfigP25Phase1" modulation="C4FM" traffic_channel_pool_size="10" ignore_data_calls="true"/>
    <!-- No channel recorder: the alias "record" id above captures playable
         per-call audio. (TRAFFIC_MBE_CALL_SEQUENCE only wrote raw .mbe frames.) -->
    <record_configuration/>
  </channel>
  <stream type="icecastHTTPConfiguration" xmlns:wstxns1="http://www.w3.org/2001/XMLSchema-instance" wstxns1:type="ICECAST_HTTP" public="false" sample_rate="8000" user_name="source" bitrate="32" channels="1" mount_point="/ems.mp3" inline="false" delay="0" host="localhost" name="MOSWIN Live" enabled="true" port="8000" password="CHANGE_ME" maximum_recording_age="0">
    <format>MP3</format>
  </stream>
</playlist>
